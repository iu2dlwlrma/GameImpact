<Window x:Class="GameImpact.UI.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        IsHitTestVisible="False">
    
    <Grid x:Name="RootGrid">
        <!-- 边框（拾取模式时显示） -->
        <Border x:Name="PickBorder" BorderThickness="3" BorderBrush="#00FF00" Visibility="Collapsed"/>
        
        <!-- 绘制层 Canvas -->
        <Canvas x:Name="DrawCanvas"/>
        
        <!-- 十字线 Canvas -->
        <Canvas x:Name="CrosshairCanvas" Visibility="Collapsed">
            <Line x:Name="CrosshairH" Stroke="#00FF00" StrokeThickness="1" StrokeDashArray="4,2"/>
            <Line x:Name="CrosshairV" Stroke="#00FF00" StrokeThickness="1" StrokeDashArray="4,2"/>
        </Canvas>
        
        <!-- 坐标显示 -->
        <Canvas x:Name="CoordCanvas" Visibility="Collapsed">
            <Border x:Name="CoordPanel" Background="#DD000000" CornerRadius="4" Padding="10,6">
                <TextBlock x:Name="CoordText" Foreground="#00FF00" FontFamily="Consolas" FontSize="14" FontWeight="Bold"/>
            </Border>
        </Canvas>
        
        <!-- 信息显示区域 -->
        <StackPanel x:Name="InfoPanel" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left"/>
    </Grid>
</Window>
